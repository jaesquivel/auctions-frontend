# build.env
# Configuration for build.sh
# Copy to build.env and fill in your production values.
# Do NOT commit build.env — it contains live Clerk keys.

# ============================================
# IMAGE
# ============================================
IMAGE_NAME=auctions-frontend

# ============================================
# CLERK (baked into the JS bundle at build time)
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/properties
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/properties

# ============================================
# API (baked into the JS bundle at build time)
# ============================================
NEXT_PUBLIC_API_PORT=8080
NEXT_PUBLIC_API_BASE_PATH=/api/v1
NEXT_PUBLIC_LOG_TOKENS=false
